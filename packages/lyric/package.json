{
	"name": "@applemusic-like-lyrics/lyric",
	"version": "0.4.1",
	"description": "一个歌词解析/生成模块，着重于歌词内容解析，支持多种格式",
	"repository": {
		"url": "https://github.com/amll-dev/applemusic-like-lyrics.git",
		"directory": "packages/lyric",
		"type": "git"
	},
	"license": "GPL-3.0",
	"nx": {
		"tags": [
			"library"
		],
		"targets": {
			"test": {
				"executor": "nx:run-commands",
				"options": {
					"command": "pnpm test",
					"cwd": "packages/lyric"
				}
			},
			"nx-release-publish": {
				"executor": "@nx/js:release-publish",
				"dependsOn": []
			}
		}
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/amll-lyric.umd.cjs",
	"module": "./dist/amll-lyric.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"types": "./dist/index.d.ts",
		"import": "./dist/amll-lyric.js",
		"require": "./dist/amll-lyric.umd.cjs"
	},
	"scripts": {
		"build:docs": "typedoc --plugin typedoc-plugin-markdown --out docs src/index.ts",
		"typecheck": "tsc --noEmit",
		"build-only": "vite build",
		"build": "run-p typecheck \"build-only {@}\" --",
		"build:dev": "vite build",
		"fmt": "biome format --write ./src",
		"dev": "vite dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"preinstall": "npx only-allow pnpm"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "^25.5.2",
		"@types/pako": "^2.0.4",
		"typescript": "^5.9.3",
		"vite": "catalog:",
		"vite-plugin-dts": "^4.3.0",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"pako": "^2.1.0"
	}
}
